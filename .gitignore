# --- Dados carregados pelo usuário (PII / negócio) ---
uploads/
data/uploads/
storage/
datasets/

# Bancos locais / caches de consulta (costumam conter cópia dos dados)
*.duckdb
*.db
*.sqlite
*.sqlite3

# Planilhas em pastas de trabalho (evita commit acidental de dados reais)
uploads/**/*.xlsx
uploads/**/*.xls
uploads/**/*.xlsm
uploads/**/*.csv
uploads/**/*.parquet
data/uploads/**/*.xlsx
data/uploads/**/*.xls
data/uploads/**/*.xlsm
data/uploads/**/*.csv
data/uploads/**/*.parquet
storage/**/*.xlsx
storage/**/*.csv
storage/**/*.parquet
datasets/**/*.xlsx
datasets/**/*.csv
datasets/**/*.parquet

# --- Artefatos de embeddings / vector store local ---
embeddings/
.chroma/
chromadb/
*.faiss
*.index
qdrant_storage/
.milvus/

# --- Logs e temporários ---
logs/
*.log
tmp/
temp/
.cache/
*.tmp
*.temp
*.bak

# --- Docker / infra local ---
.docker/
*.local.override.yml

# --- Relatórios de segurança / scanners (podem conter paths locais) ---
.bandit
safety-report.json
*.sarif

# --- Streamlit (local / segredos) ---
.streamlit/credentials.toml
.streamlit/secrets.toml
!.streamlit/credentials.toml.example

# --- Cursor / local (evitar ruído e caches grandes no diff) ---
.cursor/**/*
!.cursor/rules/
!.cursor/hooks/
