# --- Segredos e credenciais (nunca versionar) ---
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets.yaml
secrets.yml
credentials.json
*credentials*.json
service-account*.json
.gcloud/
.aws/credentials
.netrc
.npmrc
.yarnrc.yml

# --- Chaves de API em arquivos soltos ---
**/api_keys.txt
**/*_secret*
**/*_token*

# --- Ambiente virtual (nomes comuns; nunca versionar) ---
# Pastas em nomes acidentais (ex.: venv criado com nome errado na raiz)
/+/
# Venv com nome "source" na raiz (não confundir com código; aqui costuma ser ambiente)
/source/

